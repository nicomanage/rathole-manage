+/// Cumulative per-service traffic keyed by the service's public bind address.
+/// Values are (bytes_to_visitor, bytes_from_visitor). Populated by the server
+/// data path and read out via `traffic_snapshot`.
+fn traffic_registry() -> &'static TrafficMutex<TrafficMap<String, (u64, u64)>> {
+    static REG: OnceLock<TrafficMutex<TrafficMap<String, (u64, u64)>>> = OnceLock::new();
+    REG.get_or_init(|| TrafficMutex::new(TrafficMap::new()))
+}
+
+/// Snapshot of cumulative traffic per public bind address since process start.
+pub fn traffic_snapshot() -> TrafficMap<String, (u64, u64)> {
+    traffic_registry().lock().unwrap().clone()
+}
+
+/// Accumulate observed bytes for a public bind address (called by the server).
+pub(crate) fn record_traffic(bind_addr: &str, to_visitor: u64, from_visitor: u64) {
+    let mut reg = traffic_registry().lock().unwrap();
+    let entry = reg.entry(bind_addr.to_string()).or_insert((0, 0));
+    entry.0 = entry.0.saturating_add(to_visitor);
+    entry.1 = entry.1.saturating_add(from_visitor);
+}
+
+/// Live control-channel count per service name. A service has a connected
+/// client while its count is greater than zero. Counting (rather than a bool)
+/// keeps it correct across reconnects that briefly overlap the old channel.
+fn connection_registry() -> &'static TrafficMutex<TrafficMap<String, u32>> {
+    static REG: OnceLock<TrafficMutex<TrafficMap<String, u32>>> = OnceLock::new();
+    REG.get_or_init(|| TrafficMutex::new(TrafficMap::new()))
+}
+
+/// Names of services that currently have at least one connected client.
+pub fn connected_services() -> ServiceSet<String> {
+    connection_registry()
+        .lock()
+        .unwrap()
+        .iter()
+        .filter(|(_, &n)| n > 0)
+        .map(|(name, _)| name.clone())
+        .collect()
+}
+
+pub(crate) fn service_connect(name: &str) {
+    *connection_registry()
+        .lock()
+        .unwrap()
+        .entry(name.to_string())
+        .or_insert(0) += 1;
+}
+
+pub(crate) fn service_disconnect(name: &str) {
+    let mut reg = connection_registry().lock().unwrap();
+    if let Some(n) = reg.get_mut(name) {
+        *n = n.saturating_sub(1);
+    }
+}
