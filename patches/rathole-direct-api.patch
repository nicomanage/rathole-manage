+#[cfg(feature = "server")]
+fn virtual_tcp_registry() -> &'static TrafficMutex<TrafficMap<String, VirtualTcpEndpoint>> {
+    static REG: OnceLock<TrafficMutex<TrafficMap<String, VirtualTcpEndpoint>>> = OnceLock::new();
+    REG.get_or_init(|| TrafficMutex::new(TrafficMap::new()))
+}
+
+#[cfg(feature = "server")]
+pub(crate) fn register_virtual_tcp(
+    key: String,
+    visitor_tx: mpsc::Sender<VirtualVisitor>,
+    data_ch_req_tx: mpsc::UnboundedSender<bool>,
+) -> u64 {
+    static NEXT_ID: AtomicU64 = AtomicU64::new(1);
+    let id = NEXT_ID.fetch_add(1, Ordering::Relaxed);
+    virtual_tcp_registry().lock().unwrap().insert(
+        key,
+        VirtualTcpEndpoint {
+            id,
+            visitor_tx,
+            data_ch_req_tx,
+        },
+    );
+    id
+}
+
+#[cfg(feature = "server")]
+pub(crate) fn unregister_virtual_tcp(key: &str, id: u64) {
+    let mut reg = virtual_tcp_registry().lock().unwrap();
+    if reg.get(key).is_some_and(|endpoint| endpoint.id == id) {
+        reg.remove(key);
+    }
+}
+
+#[cfg(feature = "server")]
+pub async fn open_virtual_tcp(key: &str) -> Result<DuplexStream> {
+    const BUFFER_SIZE: usize = 64 * 1024;
+    let endpoint = virtual_tcp_registry()
+        .lock()
+        .unwrap()
+        .get(key)
+        .cloned()
+        .ok_or_else(|| anyhow::anyhow!("virtual TCP service is not registered: {key}"))?;
+    let (server_side, client_side) = tokio::io::duplex(BUFFER_SIZE);
+    endpoint
+        .data_ch_req_tx
+        .send(true)
+        .map_err(|_| anyhow::anyhow!("virtual TCP service is not connected: {key}"))?;
+    endpoint
+        .visitor_tx
+        .send(Box::new(server_side))
+        .await
+        .map_err(|_| anyhow::anyhow!("virtual TCP service is closed: {key}"))?;
+    Ok(client_side)
+}
