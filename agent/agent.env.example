# Optional environment for the rathole-manage agent daemon.
# Copy to /etc/rathole-manage/agent.env (all values are optional).
#
# The daemon normally reads its identity from the file written by
#   rathole-agent login
# so you usually don't need to set INSTANCE_ID / AGENT_TOKEN / HUB_URL here.

# Where the enrolled identity is stored (must match between `login` and the daemon).
IDENTITY_PATH=/var/lib/rathole-manage/identity.json

# Log verbosity for both the agent and embedded rathole.
RUST_LOG=info

# Where Let's Encrypt accounts/certificates are stored.
# Defaults to /var/lib/rathole-manage/acme when running under the packaged systemd service.
# RATHOLE_ACME_DIR=/var/lib/rathole-manage/acme

# --- Alternative: static provisioning without `login` ------------------------
# Set all three to skip enrollment and connect with pre-issued credentials.
# HUB_URL=https://rathole-manage.reall.icu
# INSTANCE_ID=00000000-0000-0000-0000-000000000000
# AGENT_TOKEN=the-agent-token-from-the-panel
