# Connection settings for the rathole-manage agent.
# Copy to /etc/rathole-manage/agent.env and fill in the values from the panel's
# "Agent setup" tab.

# WebSocket endpoint of your deployed Worker (note the /api/agent/ws path).
HUB_URL=wss://rathole-manage.<your-account>.workers.dev/api/agent/ws

# The instance id and its agent token, shown in the panel.
INSTANCE_ID=00000000-0000-0000-0000-000000000000
AGENT_TOKEN=paste-the-agent-token-here

# Where the agent writes the generated rathole config (rathole hot-reloads it).
CONFIG_PATH=/var/lib/rathole-manage/server.toml

# Optional: log verbosity for both the agent and embedded rathole.
RUST_LOG=info
